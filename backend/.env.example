# 数据库
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/diary_db

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRE_MINUTES=1440

# model_key 加密密钥（Fernet，32字节 base64url 编码）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MODEL_KEY_SECRET=

# CORS 允许的前端来源
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM 配置（系统默认，用户也可在「模型管理」中配置自己的模型）
# 支持 OpenAI、DeepSeek、通义千问等 OpenAI 兼容接口
LLM_PROVIDER=deepseek
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# 高德地图 API Key（用于天气查询，需开通"天气查询"和"地理编码"服务）
# 申请地址：https://console.amap.com/
WEATHER_API_KEY=

# Chroma 向量数据库（RAG 语义检索）
# 持久化目录，存储日记的向量索引
CHROMA_PERSIST_DIR=./chroma_data

# Embedding 模型配置（本地运行，首次加载会下载约 400MB）
# 模型名称，支持 HuggingFace 上的 SentenceTransformer 模型
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
# 向量维度，需与模型输出维度一致
EMBEDDING_DIMENSION=768

# Re-rank 重排序模型配置（本地运行，用于对召回结果精排）
# 模型名称，支持 HuggingFace 上的 CrossEncoder 模型
RERANK_MODEL=BAAI/bge-reranker-base
# 重排序后返回的最大结果数
RERANK_TOP_K=5

# 多路召回配置
# 语义检索（Chroma 向量检索）召回数量
SEMANTIC_TOP_K=20
# BM25 关键词检索召回数量
BM25_TOP_K=20

# Chunk 切分配置
# 每个 chunk 的最大字符数
CHUNK_SIZE=512
# 相邻 chunk 的重叠字符数
CHUNK_OVERLAP=50

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
